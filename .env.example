WORDPRESS_URL=https://your-site.com
WORDPRESS_USERNAME=your-username
WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx
GEMINI_API_KEY=your-gemini-api-key

# GCS for schedule storage (Excel)
GCS_BUCKET=your-bucket-name
GCS_SCHEDULE_KEY=schedules.xlsx

# OIDC verification for Cloud Scheduler -> Cloud Run
# OIDC_AUDIENCE: Cloud Run service URL (https://blog-auto-xxx.a.run.app)
OIDC_AUDIENCE=
# Comma-separated allow-list of caller service-account emails. Empty = any verified caller.
OIDC_ALLOWED_EMAILS=
# Set to "true" only for local development to skip OIDC verification.
OIDC_BYPASS=false
