# =============================================================
# DB (NEW in v2)
# Cloud SQL の MySQL 8 を想定。NODE_ENV=production のときのみ env を参照する。
# 開発時は docker-compose.yml の値（localhost:3306, develop/password/develop）が使われる。
# =============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=develop
DB_PASSWORD=password
DB_DATABASE=develop
# Cloud SQL Auth Proxy 経由 (Cloud Run) のとき
DB_SOCKET_PATH=

# =============================================================
# WordPress Application Password の暗号化キー (NEW in v2)
# AES-256-GCM の鍵。base64 推奨だが任意文字列も SHA-256 で 32 byte に正規化される。
# 生成例: openssl rand -base64 32
# =============================================================
WP_APP_PW_ENC_KEY=

# =============================================================
# AI / 画像生成
# =============================================================
ANTHROPIC_API_KEY=sk-ant-xxxxx
GEMINI_API_KEY=your-gemini-api-key

# =============================================================
# Google Search Console
# 推奨：所有者ユーザの OAuth リフレッシュトークン経由でアクセス
# 取得方法: npx ts-node scripts/gsc-auth.ts <OAuth client_secret JSON>
# v2 では各サイトの URL は sites テーブル (gsc_site_url) に保存。
# GSC_SITE_URL は ad-hoc クエリ用のデフォルトとしてのみ残す。
# =============================================================
GSC_SITE_URL=https://gakkiou.com/
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=
GSC_OAUTH_REFRESH_TOKEN=

# フォールバック：サービスアカウント / ADC
GSC_KEY_FILE=

# =============================================================
# 移行スクリプト用（旧 Excel 永続化からの移行時のみ）
# =============================================================
GCS_BUCKET=your-bucket-name
GCS_SCHEDULE_KEY=schedules.xlsx

# =============================================================
# WordPress 初期 seed 用（scripts/seeds/sites.ts が参照）
# 本番で使い終わったら削除してよい（Application Password は sites テーブルに保存される）
# =============================================================
WORDPRESS_URL=https://your-site.com
WORDPRESS_USERNAME=your-username
WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# =============================================================
# Cloud Scheduler → Cloud Run の OIDC 認証設定
# =============================================================
# 【必須】許可する OIDC トークンの audience（Cloud Run の URL）
OIDC_AUDIENCE=
# 【任意】呼び出しを許可する SA メール（カンマ区切り）
OIDC_ALLOWED_EMAILS=
# 【ローカル開発用】true で OIDC 検証スキップ
OIDC_BYPASS=false

# =============================================================
# 画面アクセス用 Basic 認証
# =============================================================
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
